# ==========================================================
# PANGLIMA Downloader — Environment Variables
# Salin file ini menjadi ".env" lalu isi nilainya masing-masing.
# JANGAN PERNAH commit file ".env" ke GitHub.
# ==========================================================

# API Key dari https://tikapi.io/developer  (WAJIB)
TIKAPI_KEY=your_tikapi_key_here

# Gunakan sandbox TikAPI untuk testing (true/false)
TIKAPI_SANDBOX=false

# Port server (khusus VPS/Render/Railway, Vercel mengabaikan ini)
PORT=3000

# Environment: development | production
NODE_ENV=production

# Origin yang diizinkan mengakses API (pisahkan dengan koma, "*" untuk semua)
ALLOWED_ORIGIN=*

# Batas request per IP per 15 menit
RATE_LIMIT_MAX=60
